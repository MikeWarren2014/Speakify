<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base theme. Using DayNight to prevent white flashes in dark mode -->
    <style name="Theme.MyApplication" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Match the background color of your Compose Surface -->
        <item name="android:windowBackground">?android:attr/colorBackground</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <!-- Transparent theme for utility activities to avoid flashes -->
    <style name="Theme.MyApplication.Transparent" parent="Theme.MyApplication">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:backgroundDimEnabled">false</item>
    </style>
</resources>