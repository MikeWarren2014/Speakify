<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base theme. Using DayNight to prevent white flashes in dark mode -->
    <style name="Theme.MyApplication" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Match the background color of your Compose Surface -->
        <item name="android:windowBackground">?android:attr/colorBackground</item>

        <!-- Android 15+ enforces edge-to-edge. These are handled by enableEdgeToEdge() in Activity -->
        <!-- We avoid setting them here to prevent Play Console deprecation warnings -->

        <!-- Modern way to handle cutouts. 'always' is preferred for Android 15+ -->
        <item name="android:windowLayoutInDisplayCutoutMode">always</item>
    </style>

    <!-- Transparent theme for utility activities to avoid flashes -->
    <style name="Theme.MyApplication.Transparent" parent="Theme.MyApplication">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:backgroundDimEnabled">false</item>
    </style>
</resources>